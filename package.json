{
  "name": "zillow-scraper-service",
  "version": "1.0.0",
  "description": "Stateless HTTP API to scrape Zillow search and listing pages via Playwright",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
