PORT=3000
API_KEY=your-secret-bearer-token

# Render: set PLAYWRIGHT_BROWSERS_PATH=0 so Chromium ships inside node_modules (fixes missing browser at runtime)
# PLAYWRIGHT_BROWSERS_PATH=0

# Optional — fewer 403s locally if Google Chrome is installed (Windows/macOS)
# PLAYWRIGHT_CHANNEL=chrome

# Optional — show browser window (local only)
# HEADFUL=1

# Chromium/CSS scale (default 1). On Windows with display scaling, 1 usually looks less “zoomed” than following OS DPI alone.
# BROWSER_DEVICE_SCALE_FACTOR=1

# Warm-up loads zillow.com first (first-party cookies). Leave unset or 1 if you see HTTP 403; set 0 only if warm-up makes blocks worse on your network.
# ZILLOW_WARMUP=0
# Ms to wait after warm-up page load (cookies / session), default 1500
# ZILLOW_WARMUP_MS=1500

# Mouse moves + gradual scroll after warm-up and after each Zillow navigation (default on). Set 0 to skip.
# ZILLOW_HUMANIZE=0
# Extra random pause after humanize (ms), default 200–600
# ZILLOW_HUMANIZE_MS_MIN=200
# ZILLOW_HUMANIZE_MS_MAX=600

# Best-effort: left mouse down on a “press and hold” control until scrape ends (default off). Raise wait if the widget hydrates late.
# ZILLOW_CHALLENGE_HOLD=1
# ZILLOW_CHALLENGE_HOLD_WAIT_MS=800

# Milliseconds after __NEXT_DATA__ appears on /search (list) loads before reading JSON (set 0 to skip)
# SEARCH_SETTLE_MS=1500

# Milliseconds to wait on homedetails pages so the payment widget can render (DOM fallback)
# PAYMENT_DOM_WAIT_MS=5500
# Uniform random total wait per detail scrape (overrides PAYMENT_DOM_WAIT_MS for that budget)
# PAYMENT_DOM_WAIT_RANDOM_RANGE=1
# PAYMENT_DOM_WAIT_MS_MIN=4000
# PAYMENT_DOM_WAIT_MS_MAX=7500
# ±ms jitter on SEARCH_SETTLE_MS, PAYMENT_DOM_SETTLE_MS, and PAYMENT_DOM_WAIT when random range is off
# DOM_TIMING_JITTER_MS=800
# Extra ms after scrolling before reading payment breakdown (calculator hydration)
# PAYMENT_DOM_SETTLE_MS=800
# Log payment band + row snippets to stderr (diagnose wrong P&I / insurance)
# PAYMENT_DEBUG=1

# Set 0 to skip scrolling/evaluating the payment breakdown in the DOM (less interaction; JSON-only payment fields)
# PAYMENT_DOM_SCRAPE=0

# Delay between CLI scrape retries (run-search.js / run-detail.js), default 2500
# CLI_RETRY_DELAY_MS=2500
# If the error looks like HTTP 403/429, wait a random time in this range before the next attempt (default 3000–5000)
# CLI_RETRY_DELAY_403_MS_MIN=3000
# CLI_RETRY_DELAY_403_MS_MAX=5000

# Outbound HTTP(S) or SOCKS5 proxy for all Zillow requests (often required on Render—use residential/mobile IP)
# PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=
# PROXY_PASSWORD=
# Or embed credentials: PROXY_SERVER=http://user:pass@proxy.example.com:8080
